
local sprintingVisualOffset = 0;
function SellswordJewelSprintingVisual()
    if env(GetSpEffectID, Jewel_of_the_Relentless) == FALSE then -- Jewel of the Relentless (Sellsword)
        return
    end

    if sprintingVisualOffset == 10 then
        act(AddSpEffect, 390505) -- Sprinting Visual
        sprintingVisualOffset = 0
    else 
        sprintingVisualOffset = sprintingVisualOffset + 1 
    end
end