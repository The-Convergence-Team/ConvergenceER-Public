Stormcaller_DoubleJumpAllowed = false

function StormJewel_WeaponDamageBuff()
    if env(GetSpEffectID, 391140) == FALSE then -- Storm Jewel Spell Buff
        act(ClearSpEffect, 391130) -- Storm Jewel Weapon Buff
        return
    end

    IsUsingClassWeapon(true, true, false, PARAM.EquipParamWeapon.PHYSICAL_DAMAGE, 391130)
end