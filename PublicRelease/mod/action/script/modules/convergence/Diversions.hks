LAST_ATTACK_HAND = -1
LAST_HKB_STATES = { } -- Last, Second to Last, Third to Last
hkbFireEvent = AttachAfter(hkbFireEvent, function(state)
    -- Log(state)
    -- Log(debug.traceback())
    AnimationLoggerPrep(state)
    if (#LAST_HKB_STATES == 2) then
        table.remove(LAST_HKB_STATES, 2)
    end
    table.insert(LAST_HKB_STATES, 1, state)
    
    CorpaMagica()

    if state == "W_FallDeath" then
        OnDeath()
    end

    if string.find(state, "Left") or (string.find(state, "Both") and c_Style == HAND_LEFT_BOTH) then
        LAST_ATTACK_HAND = HAND_LEFT
    else
        LAST_ATTACK_HAND = HAND_RIGHT
    end
end)

Fire = AttachBefore(Fire, function(state)
    AnimationLogger(state)
    --Log(state)
    --Log(debug.traceback())
end)

