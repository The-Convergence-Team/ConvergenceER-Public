function AttachAfter(func, attachedAfter)
    local oldFunc = func
    return function(...)
        local result = oldFunc(...)
        attachedAfter(...)
        return result
    end
end

function AttachBefore(func, attachedBefore)
    local oldFunc = func
    return function(...)
        attachedBefore(...)
        return oldFunc(...)
    end
end

function AttachAfterConditional(func, condition, attachedAfter)
    local oldFunc = func
    return function(...)
        local result = oldFunc(...)
        if result == condition then
            attachedAfter(...)
        end
        return result
    end
end

